{
  "name": "storyforge-interactive-narrative",
  "version": "0.1.2",
  "private": true,
  "description": "StoryForge - 基于 LLM 的互动叙事生成器",
  "repository": {
    "type": "git",
    "url": "https://github.com/Caser-86/storyforge-interactive-narrative.git"
  },
  "scripts": {
    "dev": "next dev --webpack",
    "build": "next build --webpack",
    "start": "next start",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "db:init": "tsx src/scripts/init-db.ts",
    "db:smoke": "tsx src/scripts/db-smoke-test.ts",
    "db:sqlite:smoke": "tsx src/scripts/sqlite-smoke-test.ts",
    "db:sqlite:backup": "tsx src/scripts/sqlite-backup.ts",
    "llm:smoke": "tsx src/scripts/llm-smoke-test.ts",
    "worker": "tsx src/scripts/asset-worker.ts",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1048.0",
    "better-sqlite3": "^12.10.0",
    "bullmq": "^5",
    "geist": "^1.7.0",
    "ioredis": "^5",
    "next": "^16.2.9",
    "openai": "^4",
    "pg": "^8",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "uuid": "^11",
    "zod": "^3",
    "zustand": "^5"
  },
  "overrides": {
    "next": {
      "postcss": "8.5.15"
    }
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "^4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/uuid": "^10.0.0",
    "eslint": "^9",
    "eslint-config-next": "^16.2.9",
    "tailwindcss": "^4",
    "tsx": "^4",
    "typescript": "5.9.3",
    "vitest": "^4.1.6"
  }
}
